# Bounding box for Overpass query: min_lat,min_lon,max_lat,max_lon (south,west,north,east)
BBOX=52.490,13.495,52.525,13.545

# Human-readable area name (used in log messages)
AREA_NAME=Tierpark Berlin

# Comma-separated Overpass tag filters.
# Each entry is either a bare key ("zoo") or a key=value pair ("tourism=zoo").
OSM_TAGS=attraction=animal

# Overpass API endpoint
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Path to the DuckDB database file (relative to repo root when run from repo root)
DB_PATH=pipeline/zoo.duckdb

# Directory for caching downloaded files
CACHE_DIR=pipeline/cache

# Output path for the final GeoJSON (relative to repo root)
OUTPUT_PATH=data/animals.geojson

# Language code for Wikipedia fetches
WIKIDATA_LANG=en
